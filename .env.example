# ── Plex ──────────────────────────────────────────────────────────────────────
# URL of your Plex server (required)
PLEX_BASEURL=http://192.168.1.10:32400
# Name of your Plex music library section (required)
PLEX_MUSIC_LIBRARY=Music
# Set to 0 to skip SSL verification for self-signed certificates
PLEX_VERIFY_SSL=1

# ── Web UI ─────────────────────────────────────────────────────────────────────
# Recommended: set a long random string to keep sessions valid across restarts
WEBUI_SECRET_KEY=
# Public URL for this container — required for Plex OAuth callbacks
# e.g. http://192.168.1.10:5000
WEBUI_PUBLIC_URL=
# Port the web interface listens on
WEBUI_PORT=5000
# Require Plex sign-in to access the Web UI (recommended: 1)
WEBUI_REQUIRE_PLEX_LOGIN=1

# ── Last.fm ────────────────────────────────────────────────────────────────────
# API key is bundled — no setup needed for basic use.
# Override only if you have your own Last.fm API key.
# LASTFM_API_KEY=your_optional_override_key
# Optional single-user fallback (preferred: each user links their account in Settings)
LASTFM_USERNAME=

# Last.fm recommendation mode
# - recommendations: generate recs using track.getSimilar (default)
# - weekly_plays:    last week's listening chart
LASTFM_MODE=recommendations
LASTFM_SEED_COUNT=25
LASTFM_SIMILAR_PER_SEED=5

# ── Spotify (optional) ─────────────────────────────────────────────────────────
# Enables the Spotify URL import feature (paste a playlist/album/track link).
# No developer app required — works with the built-in anonymous token.
# If you have a high-traffic setup and hit Spotify rate limits, you can supply
# your own client ID from https://developer.spotify.com/dashboard
# SPOTIFY_CLIENT_ID=your_optional_override_id

# ── Scheduling ─────────────────────────────────────────────────────────────────
# Timezone for Auto Discovery schedules (e.g. America/New_York, Europe/London)
TZ=America/New_York
# Default schedule shown in the Web UI when a user first enables Auto Discovery
# Format: min hour day month dow  (e.g. "0 5 * * 1" = every Monday at 5 AM)
CRON_SCHEDULE=0 5 * * 1
# Run discovery immediately on container start, then follow the schedule
RUN_ON_STARTUP=false

# ── Playlist & Discovery ───────────────────────────────────────────────────────
PLAYLIST_NAME=Discover Weekly
MAX_TRACKS=50
# Set 1 to generate reports without downloading or modifying Plex
DRY_RUN=0
# When set, writes CSV discovery reports to this path
REPORT_PATH=
# Set 0 to skip the acquisition (download) step entirely
DISCOVERY_ACQUIRE=1
# tidal or qobuz
SCRAPER_SERVICE=tidal

# ── Download Performance ───────────────────────────────────────────────────────
DOWNLOAD_CONCURRENCY=6
SCRAPER_WORKERS=8

# ── Import Step (optional) ─────────────────────────────────────────────────────
# Run a tagging/import command for files you already own
ENABLE_IMPORT=0
IMPORT_INBOX_DIR=/inbox
IMPORT_CMD=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
